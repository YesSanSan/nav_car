#   PathMatch: [.*/.c, .*/.h]
# CompileFlags:
#   Add:
#     - "-std=c11"
# ---
# If:
#   PathMatch: [.*/.cpp, .*/.hpp]
# CompileFlags:
#   Add:
#     - "-std=c++14"
            