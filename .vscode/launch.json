    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/nav_car.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "configFiles": [ "D:/scoop/apps/openocd-esp/current/openocd-esp32/share/openocd/scripts/interface/cmsis-dap.cfg", "D:/scoop/apps/openocd-esp/current/openocd-esp32/share/openocd/scripts/target/stm32h7x.cfg" ],
            "device": "stm32h7",
            "armToolchainPath": "D:/scoop/apps/gcc-arm-none-eabi/current/",
            "gdbPath": "D:/scoop/apps/gcc-arm-none-eabi/current/bin/arm-none-eabi-gdb.exe",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        }
    ]
}
